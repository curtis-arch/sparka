    "models:base": "tsx scripts/models/fetch-base.ts",
    "models:endpoints": "tsx scripts/models/fetch-endpoints.ts",
    "models:extra": "bun scripts/models/fetch-extra.ts",
    "models:sync": "SKIP_EXISTING=1 tsx scripts/models/sync.ts",
    "models:sync:all": "OVERWRITE_MODELS=1 tsx scripts/models/sync.ts",
    "test": "export PLAYWRIGHT=True && bunx playwright test --workers=4",
    "test:unit": "vitest run",
    "test:types": "next typegen . && tsc --noEmit"
